{
  "name": "spa-inventory-shoes-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/setup-env.sh && vite --host",
    "build": "npm run generate-routes && tsc -b && vite build",
    "lint": "eslint .",
